<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<configuration xmlns="http://www.jooq.org/xsd/jooq-codegen-3.19.0.xsd">
    <logging>WARN</logging>
    <jdbc>
        <driver>com.mysql.cj.jdbc.Driver</driver>
        <url>__JDBC_URL__</url>
        <user>stroomuser</user>
        <password>stroompassword1</password>
    </jdbc>
    <generator>
        <name>org.jooq.codegen.JavaGenerator</name>
        <database>
            <name>org.jooq.meta.mysql.MySQLDatabase</name>
            <inputSchema>__INPUT_SCHEMA__</inputSchema>
            <outputSchema>stroom</outputSchema>
            <includes>analytic_tracker|execution_schedule|execution_history|execution_tracker</includes>
            <excludes>analytic_schema_history</excludes>
            <recordVersionFields>version</recordVersionFields>
            <forcedTypes>
                <forcedType>
                    <name>BOOLEAN</name>
                    <includeExpression>.*\.execution_schedule\.enabled|.*\.execution_schedule\.contiguous</includeExpression>
                    <includeTypes>(?i:tinyint)(\(1\))?</includeTypes>
                </forcedType>
            </forcedTypes>
        </database>
        <generate>
            <implicitJoinPathsToOne>false</implicitJoinPathsToOne>
            <implicitJoinPathsToMany>false</implicitJoinPathsToMany>
        </generate>
        <target>
            <packageName>stroom.analytics.impl.db.jooq</packageName>
            <directory>__OUTPUT_DIR__</directory>
        </target>
    </generator>
</configuration>
