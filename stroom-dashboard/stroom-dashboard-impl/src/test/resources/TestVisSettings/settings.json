{
  "data": {
    "structure": {
      "nest": {
        "key": {
          "id": "${series}",
          "sort": {
            "direction": "${sortSeries}",
            "enabled": "true"
          }
        },
        "limit": {
          "enabled": "true",
          "size": "${maxSeries}"
        },
        "values": {
          "fields": [
            {
              "id": "${x}",
              "sort": {
                "direction": "ascending",
                "enabled": "true"
              }
            },
            {
              "id": "${y}"
            }
          ],
          "limit": {
            "enabled": "true",
            "size": "5"
          }
        }
      }
    }
  },
  "tabs": [
    {
      "controls": [
        {
          "id": "x",
          "label": "XAxis",
          "type": "field"
        },
        {
          "id": "y",
          "label": "YAxis",
          "type": "field"
        },
        {
          "id": "series",
          "label": "Series",
          "type": "field"
        }
      ],
      "name": "Data"
    },
    {
      "controls": [
        {
          "defaultValue": "basis-open",
          "id": "interpolationMode",
          "label": "InterpolationMode",
          "type": "selection",
          "values": [
            "linear",
            "linear-closed",
            "step",
            "step-before",
            "step-after",
            "basis",
            "basis-open",
            "basis-closed",
            "bundle",
            "cardinal",
            "cardinal-open",
            "cardinal-closed",
            "monotone"
          ]
        },
        {
          "defaultValue": "ascending",
          "id": "sortSeries",
          "label": "SortSeries",
          "type": "selection",
          "values": [
            "",
            "ascending",
            "descending"
          ]
        },
        {
          "defaultValue": "10",
          "id": "maxSeries",
          "label": "MaxSeries",
          "type": "number"
        }
      ],
      "name": "Line"
    }
  ]
}
