<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:c="urn:import:stroom.widget.customdatebox.client"
             xmlns:form="urn:import:stroom.widget.form.client"
             xmlns:tickbox="urn:import:stroom.widget.tickbox.client.view"
             xmlns:b="urn:import:stroom.widget.button.client"
             xmlns:v="urn:import:stroom.widget.valuespinner.client"
             xmlns:l="urn:import:stroom.item.client">
    <g:FlowPanel styleName="max form">
        <form:FormGroup identity="processorEditExpression" label="Expression" addStyleNames="dock-max">
            <g:SimplePanel ui:field="expression" styleName="max default-min-sizes"/>
        </form:FormGroup>
        <form:FormGroup identity="processorEditMinMetaCreateTimeMs" label="Min Create Time">
            <c:MyDateBox ui:field="minMetaCreateTimeMs"/>
        </form:FormGroup>
        <form:FormGroup identity="processorEditMaxMetaCreateTimeMs" label="Max Create Time">
            <c:MyDateBox ui:field="maxMetaCreateTimeMs"/>
        </form:FormGroup>
        <form:FormGroup identity="processorEditMaxProcessingTasks"
                        label="Max Processing Tasks"
                        helpText="Choose the maximum number of tasks that will be processed concurrently across the cluster.">
            <v:ValueSpinner ui:field="maxProcessingTasks"
                            addStyleNames="dock-max"
                            wrapValues="true"/>
        </form:FormGroup>
        <form:FormGroup identity="processorEditProfile"
                        label="Processing Profile"
                        helpText="The processing profile to use. Profiles control max concurrent tasks for individual nodes and the entire cluster.">
            <l:SelectionBox ui:field="profile"/>
        </form:FormGroup>
        <form:FormGroup identity="processorEditExport" label="Include in Export">
            <tickbox:CustomCheckBox ui:field="export"/>
        </form:FormGroup>
        <form:FormGroup identity="runAsUser" label="Run As User">
            <g:SimplePanel ui:field="runAsUser"/>
        </form:FormGroup>
        <form:FormGroup identity="processorEditFeedDependencies"
                        label="Set Feed Dependencies">
            <b:Button addStyleNames="dock-min allow-focus"
                      ui:field="editFeedDependencies"
                      text="Set Feed Dependencies"/>
        </form:FormGroup>
    </g:FlowPanel>
</ui:UiBinder>