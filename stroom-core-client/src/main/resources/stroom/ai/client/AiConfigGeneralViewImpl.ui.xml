<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:l="urn:import:stroom.item.client"
             xmlns:v="urn:import:stroom.widget.valuespinner.client"
             xmlns:form="urn:import:stroom.widget.form.client"
             xmlns:tickbox="urn:import:stroom.widget.tickbox.client.view">
    <g:FlowPanel styleName="max default-min-sizes dock-container-vertical">
        <form:FormGroup identity="model"
                        label="Model">
            <g:SimplePanel ui:field="modelRef"/>
        </form:FormGroup>
        <form:FormGroup identity="dockTypeSelectionBox" label="Dock Type">
            <l:SelectionBox ui:field="dockTypeSelectionBox"/>
        </form:FormGroup>
        <form:FormGroup identity="dockLocationSelectionBox" label="Dock Location">
            <l:SelectionBox ui:field="dockLocationSelectionBox"/>
        </form:FormGroup>
        <form:FormGroup identity="chatSystemPrompt" label="Chat System Prompt">
            <g:TextArea ui:field="chatSystemPrompt" width="100%" visibleLines="5"/>
        </form:FormGroup>
        <form:FormGroup identity="historySummaryPrompt" label="History Summary Prompt">
            <g:TextArea ui:field="historySummaryPrompt" width="100%" visibleLines="3"/>
        </form:FormGroup>
        <form:FormGroup identity="maxHistorySafetyCapMessages" label="Max History Safety Cap">
            <v:ValueSpinner ui:field="maxHistorySafetyCapMessages" width="200px"/>
        </form:FormGroup>
        <form:FormGroup>
            <tickbox:CustomCheckBox ui:field="enableDebugDetail"
                                    identity="enableDebugDetail"
                                    label="Enable Debug Detail"/>
        </form:FormGroup>
    </g:FlowPanel>
</ui:UiBinder>
